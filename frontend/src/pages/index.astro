---
import Layout from '../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<Layout title="VISIONSCAN — AI Image Forensics">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-brand">
        <div class="brand-icon">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="16" cy="16" r="8" stroke="currentColor" stroke-width="1"/>
            <circle cx="16" cy="16" r="3" fill="currentColor"/>
            <line x1="2" y1="16" x2="8" y2="16" stroke="currentColor" stroke-width="1.5"/>
            <line x1="24" y1="16" x2="30" y2="16" stroke="currentColor" stroke-width="1.5"/>
            <line x1="16" y1="2" x2="16" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <line x1="16" y1="24" x2="16" y2="30" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="brand-name font-display">VISION<span>SCAN</span></span>
      </div>
      <div class="nav-links">
        <a href="/" class="nav-link active">ANALYZE</a>
        <a href="/history" class="nav-link">HISTORY</a>
      </div>
      <div class="nav-status">
        <span class="status-dot"></span>
        <span class="font-mono" style="font-size:0.7rem;color:var(--text-secondary)">SYSTEM ONLINE</span>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-text font-display">FORENSICS</div>
    <div class="hero-content">
      <div class="hero-tag font-mono">[ AI IMAGE DETECTION SYSTEM v2.4 ]</div>
      <h1 class="hero-title font-display">
        DETECT <span class="text-cyan glow-cyan">AI</span><br />
        FORGERIES
      </h1>
      <p class="hero-sub">
        Advanced forensic analysis using Error Level Analysis, frequency decomposition,
        and deep-learning classification to identify AI-generated and AI-modified images.
      </p>
    </div>
    <div class="hero-stats" id="statsBar">
      <div class="stat-item">
        <span class="stat-val font-mono" id="totalCount">--</span>
        <span class="stat-label">ANALYZED</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-val font-mono text-red" id="aiCount">--</span>
        <span class="stat-label">AI GENERATED</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-val font-mono text-orange" id="modCount">--</span>
        <span class="stat-label">AI MODIFIED</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-val font-mono text-green" id="realCount">--</span>
        <span class="stat-label">AUTHENTIC</span>
      </div>
    </div>
  </section>

  <!-- UPLOAD ZONE -->
  <section class="upload-section">
    <div class="upload-container panel corner-tl corner-br">
      <div class="upload-header">
        <span class="font-display" style="font-size:0.7rem;letter-spacing:0.15em;color:var(--cyan)">
          ▶ UPLOAD IMAGE FOR ANALYSIS
        </span>
        <span class="font-mono" style="font-size:0.65rem;color:var(--text-dim)">
          JPEG · PNG · WEBP · BMP · MAX 15MB
        </span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="drop-ring">
          <div class="drop-icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 8 L32 44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M20 32 L32 44 L44 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 52 L54 52" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <rect x="6" y="14" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
              <rect x="42" y="8" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
              <circle cx="14" cy="22" r="2" fill="currentColor" opacity="0.4"/>
              <circle cx="50" cy="16" r="2" fill="currentColor" opacity="0.4"/>
            </svg>
          </div>
          <p class="drop-text font-mono">DROP IMAGE FILE HERE</p>
          <p class="drop-sub">or</p>
          <label class="btn-primary" style="cursor:pointer;">
            <span>BROWSE FILES</span>
            <input type="file" id="fileInput" accept="image/*" style="display:none;" />
          </label>
        </div>

        <!-- Preview area (hidden until file selected) -->
        <div class="preview-area" id="previewArea" style="display:none;">
          <div class="preview-img-wrap">
            <img id="previewImg" src="" alt="Preview" />
            <div class="preview-overlay font-mono">READY FOR SCAN</div>
          </div>
          <div class="preview-meta" id="previewMeta"></div>
          <div class="preview-actions">
            <button class="btn-primary" id="analyzeBtn">
              <span>⬡ INITIATE SCAN</span>
            </button>
            <button class="btn-ghost" id="clearBtn">CLEAR</button>
          </div>
        </div>
      </div>
    </div>

    <!-- LOADING STATE -->
    <div class="loading-state" id="loadingState" style="display:none;">
      <div class="scanner-anim">
        <div class="scanner-frame">
          <div class="scanner-line"></div>
          <div class="scanner-corners">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
        <div class="loading-steps" id="loadingSteps">
          <div class="load-step active font-mono">[ 01 ] Uploading image data...</div>
          <div class="load-step font-mono">[ 02 ] Running ELA analysis...</div>
          <div class="load-step font-mono">[ 03 ] Frequency decomposition...</div>
          <div class="load-step font-mono">[ 04 ] AI classifier inference...</div>
          <div class="load-step font-mono">[ 05 ] Marking suspicious regions...</div>
          <div class="load-step font-mono">[ 06 ] Compiling forensic report...</div>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTS SECTION -->
  <section class="results-section" id="resultsSection" style="display:none;">
    <div class="results-header">
      <div class="rh-left">
        <span class="font-mono" style="color:var(--text-dim);font-size:0.7rem;">FORENSIC ANALYSIS REPORT</span>
        <h2 class="font-display" style="font-size:1.6rem;letter-spacing:0.05em;">SCAN COMPLETE</h2>
      </div>
      <button class="btn-primary" id="newScanBtn" style="font-size:0.65rem;">
        <span>⟳ NEW SCAN</span>
      </button>
    </div>

    <!-- VERDICT BANNER -->
    <div class="verdict-banner" id="verdictBanner">
      <div class="vb-left">
        <div class="verdict-icon" id="verdictIcon">⬡</div>
        <div class="verdict-info">
          <span class="verdict-label font-mono" style="font-size:0.7rem;">VERDICT</span>
          <span class="verdict-text font-display" id="verdictText">--</span>
        </div>
      </div>
      <div class="vb-right">
        <div class="confidence-meter">
          <span class="font-mono" style="font-size:0.65rem;color:var(--text-dim);">CONFIDENCE</span>
          <div class="meter-bar">
            <div class="meter-fill" id="meterFill"></div>
          </div>
          <span class="font-display" id="confidenceVal" style="font-size:1.4rem;">--%</span>
        </div>
      </div>
    </div>

    <!-- SIGNAL METRICS -->
    <div class="metrics-row">
      <div class="metric-card panel">
        <span class="metric-label font-mono">AI PROBABILITY</span>
        <span class="metric-val font-display" id="aiProb">--%</span>
        <div class="metric-bar"><div class="metric-fill" id="aiProbBar" style="background:var(--red-alert)"></div></div>
      </div>
      <div class="metric-card panel">
        <span class="metric-label font-mono">ELA SCORE</span>
        <span class="metric-val font-display" id="elaScore">--</span>
        <div class="metric-bar"><div class="metric-fill" id="elaBar" style="background:var(--orange)"></div></div>
      </div>
      <div class="metric-card panel">
        <span class="metric-label font-mono">FREQ ANOMALY</span>
        <span class="metric-val font-display" id="freqScore">--</span>
        <div class="metric-bar"><div class="metric-fill" id="freqBar" style="background:var(--cyan)"></div></div>
      </div>
      <div class="metric-card panel">
        <span class="metric-label font-mono">REGIONS FLAGGED</span>
        <span class="metric-val font-display" id="regionsCount">--</span>
        <div class="metric-bar"><div class="metric-fill" id="regionsBar" style="background:var(--cyan)"></div></div>
      </div>
    </div>

    <!-- IMAGE COMPARISON -->
    <div class="comparison-grid">
      <!-- Original -->
      <div class="img-panel panel">
        <div class="img-panel-header">
          <span class="font-mono">ORIGINAL</span>
          <span class="img-tag font-mono" id="origSize">--</span>
        </div>
        <div class="img-wrap">
          <img id="origImg" src="" alt="Original image" />
        </div>
      </div>

      <!-- Annotated -->
      <div class="img-panel panel annotated-panel">
        <div class="img-panel-header">
          <span class="font-mono">ANNOTATED — FLAGGED REGIONS</span>
          <span class="img-tag font-mono" id="regionTag">-- REGIONS</span>
        </div>
        <div class="img-wrap">
          <img id="annotatedImg" src="" alt="Annotated image" />
        </div>
      </div>

      <!-- ELA Heatmap -->
      <div class="img-panel panel ela-panel">
        <div class="img-panel-header">
          <span class="font-mono">ELA HEATMAP</span>
          <span class="img-tag font-mono" style="color:var(--orange)">ERROR LEVEL ANALYSIS</span>
        </div>
        <div class="img-wrap">
          <img id="elaImg" src="" alt="ELA heatmap" />
        </div>
      </div>
    </div>

    <!-- TECHNICAL READOUT -->
    <div class="tech-readout panel">
      <div class="tr-header">
        <span class="font-display" style="font-size:0.7rem;letter-spacing:0.1em;color:var(--cyan)">
          ▶ TECHNICAL READOUT
        </span>
      </div>
      <div class="tr-grid font-mono" id="techGrid">
        <!-- Populated by JS -->
      </div>
    </div>
  </section>

  <!-- RECENT HISTORY -->
  <section class="recent-section">
    <div class="section-header">
      <span class="font-display" style="font-size:0.7rem;letter-spacing:0.15em;color:var(--cyan)">
        ▶ RECENT ANALYSES
      </span>
      <a href="/history" class="btn-primary" style="font-size:0.65rem;padding:0.5rem 1rem;">
        <span>VIEW ALL</span>
      </a>
    </div>
    <div class="history-table panel">
      <div class="ht-head font-mono">
        <span>FILENAME</span>
        <span>VERDICT</span>
        <span>CONFIDENCE</span>
        <span>REGIONS</span>
        <span>TIME</span>
      </div>
      <div id="recentList">
        <div class="ht-empty font-mono">No analyses yet. Upload an image to begin.</div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── NAV ─────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(2, 4, 8, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-dim);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .brand-icon {
    width: 28px;
    height: 28px;
    color: var(--cyan);
    animation: spin-slow 20s linear infinite;
  }

  .brand-name {
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .brand-name span { color: var(--cyan); }

  .nav-links { display: flex; gap: 2rem; margin-left: 2rem; }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--cyan);
    border-bottom-color: var(--cyan);
  }

  .nav-status { margin-left: auto; display: flex; align-items: center; gap: 0.5rem; }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green-ok);
    box-shadow: 0 0 8px var(--green-ok);
    animation: pulse-border 2s ease infinite;
  }

  /* ── HERO ─────────────────────────────────────────── */
  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 12rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 200, 255, 0.05);
    pointer-events: none;
    white-space: nowrap;
    user-select: none;
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-tag {
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
    animation: fadeInUp 0.6s ease both;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s ease 0.1s both;
  }

  .hero-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .hero-stats {
    display: flex;
    gap: 0;
    margin-top: 3rem;
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    overflow: hidden;
    animation: fadeInUp 0.6s ease 0.3s both;
    background: var(--bg-panel);
  }

  .stat-item {
    flex: 1;
    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-val { font-size: 1.6rem; font-weight: 700; }
  .stat-label { font-size: 0.6rem; letter-spacing: 0.15em; color: var(--text-dim); }
  .stat-divider { width: 1px; background: var(--border-dim); }

  /* ── UPLOAD ─────────────────────────────────────────── */
  .upload-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .upload-container {
    padding: 0;
    overflow: visible;
  }

  .upload-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--border-dim);
  }

  .dropzone {
    min-height: 320px;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: background 0.3s;
  }

  .dropzone.drag-over {
    background: rgba(0, 200, 255, 0.04);
  }

  .drop-ring {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .drop-icon {
    width: 80px;
    height: 80px;
    color: var(--cyan-dim);
    animation: fadeInUp 0.5s ease both;
  }

  .drop-text {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: var(--text-secondary);
  }

  .drop-sub { color: var(--text-dim); font-size: 0.8rem; }

  /* Preview */
  .preview-area {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .preview-img-wrap {
    position: relative;
    max-width: 500px;
    width: 100%;
  }

  .preview-img-wrap img {
    width: 100%;
    max-height: 300px;
    object-fit: contain;
    border: 1px solid var(--border-dim);
    border-radius: 4px;
  }

  .preview-overlay {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--cyan);
    background: rgba(2, 4, 8, 0.8);
    padding: 0.25rem 0.5rem;
  }

  .preview-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    text-align: center;
  }

  .preview-actions { display: flex; gap: 1rem; align-items: center; }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border-dim);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .btn-ghost:hover {
    border-color: var(--text-secondary);
    color: var(--text-secondary);
  }

  /* ── LOADING ─────────────────────────────────────────── */
  .loading-state {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .scanner-anim {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    padding: 2rem;
    border: 1px solid var(--border-dim);
    background: var(--bg-panel);
  }

  .scanner-frame {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    position: relative;
    border: 1px solid var(--border-active);
  }

  .scanner-line {
    position: absolute;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    top: 0;
    animation: scan-line 2s ease-in-out infinite;
    box-shadow: 0 0 10px var(--cyan);
  }

  .scanner-corners span {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: var(--cyan);
    border-style: solid;
  }

  .scanner-corners span:nth-child(1) { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .scanner-corners span:nth-child(2) { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .scanner-corners span:nth-child(3) { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .scanner-corners span:nth-child(4) { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

  .loading-steps { display: flex; flex-direction: column; gap: 0.5rem; }

  .load-step {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .load-step.active { color: var(--cyan); }
  .load-step.done { color: var(--green-ok); }
  .load-step.done::before { content: '✓ '; }

  /* ── RESULTS ─────────────────────────────────────────── */
  .results-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: fadeInUp 0.5s ease both;
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .verdict-banner {
    border: 1px solid var(--border-active);
    background: var(--bg-panel);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    position: relative;
    overflow: hidden;
  }

  .verdict-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--verdict-color, var(--cyan));
    opacity: 0.04;
  }

  .vb-left { display: flex; align-items: center; gap: 1.5rem; }

  .verdict-icon {
    font-size: 2.5rem;
    color: var(--verdict-color, var(--cyan));
    text-shadow: 0 0 20px var(--verdict-color, var(--cyan));
    animation: flicker 5s ease infinite;
  }

  .verdict-info { display: flex; flex-direction: column; gap: 0.25rem; }

  .verdict-text {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--verdict-color, var(--cyan));
    text-shadow: 0 0 20px var(--verdict-color, var(--cyan));
  }

  .confidence-meter {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .meter-bar {
    width: 200px;
    height: 4px;
    background: var(--bg-card);
    border-radius: 2px;
    overflow: hidden;
  }

  .meter-fill {
    height: 100%;
    background: var(--verdict-color, var(--cyan));
    border-radius: 2px;
    transition: width 1s ease;
    box-shadow: 0 0 10px var(--verdict-color, var(--cyan));
  }

  /* METRICS ROW */
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .metric-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-label {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
  }

  .metric-val {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .metric-bar {
    height: 3px;
    background: var(--bg-card);
    border-radius: 2px;
    margin-top: 0.25rem;
    overflow: hidden;
  }

  .metric-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 1s ease 0.3s;
    width: 0;
  }

  /* IMAGE COMPARISON */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .ela-panel {
    grid-column: 1 / -1;
  }

  .img-panel { overflow: hidden; }

  .img-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
  }

  .img-tag {
    font-size: 0.65rem;
    color: var(--cyan);
    letter-spacing: 0.1em;
  }

  .img-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    background: var(--bg-deep);
    min-height: 200px;
  }

  .img-wrap img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
    border-radius: 2px;
  }

  .annotated-panel .img-panel-header { border-color: rgba(255, 51, 51, 0.3); }
  .annotated-panel::before { background: linear-gradient(90deg, transparent, rgba(255, 51, 51, 0.3), transparent); }
  .ela-panel .img-panel-header { border-color: rgba(255, 140, 0, 0.3); }
  .ela-panel::before { background: linear-gradient(90deg, transparent, rgba(255, 140, 0, 0.2), transparent); }

  /* TECH READOUT */
  .tech-readout { overflow: hidden; }

  .tr-header {
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--border-dim);
  }

  .tr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0;
  }

  .tr-row {
    display: flex;
    justify-content: space-between;
    padding: 0.7rem 1.5rem;
    border-bottom: 1px solid var(--border-dim);
    font-size: 0.72rem;
    transition: background 0.2s;
  }

  .tr-row:hover { background: var(--bg-hover); }
  .tr-key { color: var(--text-dim); }
  .tr-val { color: var(--text-primary); }

  /* RECENT SECTION */
  .recent-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .history-table { overflow: hidden; }

  .ht-head {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr 1fr 1.5fr;
    padding: 0.6rem 1.5rem;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border-dim);
    background: var(--bg-deep);
  }

  .ht-row {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr 1fr 1.5fr;
    padding: 0.8rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border-bottom: 1px solid var(--border-dim);
    transition: background 0.2s;
    align-items: center;
  }

  .ht-row:hover { background: var(--bg-hover); }
  .ht-row:last-child { border-bottom: none; }

  .ht-empty {
    padding: 2rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    text-align: center;
  }

  .verdict-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
    display: inline-block;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero-bg-text { font-size: 5rem; }
    .hero-stats { flex-direction: column; }
    .stat-divider { width: 100%; height: 1px; }
    .metrics-row { grid-template-columns: repeat(2, 1fr); }
    .comparison-grid { grid-template-columns: 1fr; }
    .ela-panel { grid-column: auto; }
    .ht-head, .ht-row { grid-template-columns: 2fr 1fr 1fr; }
    .ht-head span:nth-child(4),
    .ht-head span:nth-child(5),
    .ht-row span:nth-child(4),
    .ht-row span:nth-child(5) { display: none; }
    .meter-bar { width: 120px; }
    .nav-links { display: none; }
  }
</style>

<script define:vars={{ API_URL }}>
  const API = API_URL;

  // ─── DOM refs ────────────────────────────────────────────────────────────────
  const dropzone       = document.getElementById('dropzone');
  const fileInput      = document.getElementById('fileInput');
  const previewArea    = document.getElementById('previewArea');
  const previewImg     = document.getElementById('previewImg');
  const previewMeta    = document.getElementById('previewMeta');
  const analyzeBtn     = document.getElementById('analyzeBtn');
  const clearBtn       = document.getElementById('clearBtn');
  const loadingState   = document.getElementById('loadingState');
  const resultsSection = document.getElementById('resultsSection');
  const newScanBtn     = document.getElementById('newScanBtn');

  let selectedFile = null;

  // ─── Drag & Drop ──────────────────────────────────────────────────────────
  dropzone.addEventListener('dragover', e => {
    e.preventDefault();
    dropzone.classList.add('drag-over');
  });
  dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
  dropzone.addEventListener('drop', e => {
    e.preventDefault();
    dropzone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) setFile(file);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) setFile(fileInput.files[0]);
  });

  function setFile(file) {
    selectedFile = file;
    const url = URL.createObjectURL(file);
    previewImg.src = url;
    previewMeta.textContent = `${file.name}  ·  ${(file.size / 1024).toFixed(1)} KB  ·  ${file.type}`;
    dropzone.querySelector('.drop-ring').style.display = 'none';
    previewArea.style.display = 'flex';
  }

  clearBtn.addEventListener('click', () => {
    selectedFile = null;
    fileInput.value = '';
    previewArea.style.display = 'none';
    dropzone.querySelector('.drop-ring').style.display = 'flex';
    resultsSection.style.display = 'none';
  });

  newScanBtn.addEventListener('click', () => clearBtn.click());

  // ─── Analyze ──────────────────────────────────────────────────────────────
  analyzeBtn.addEventListener('click', async () => {
    if (!selectedFile) return;

    // Show loading
    loadingState.style.display = 'block';
    resultsSection.style.display = 'none';
    analyzeBtn.disabled = true;

    const steps = loadingState.querySelectorAll('.load-step');
    let stepIdx = 0;
    const stepInterval = setInterval(() => {
      if (stepIdx > 0) steps[stepIdx - 1].classList.replace('active', 'done');
      if (stepIdx < steps.length) {
        steps[stepIdx].classList.add('active');
        stepIdx++;
      }
    }, 800);

    try {
      const form = new FormData();
      form.append('file', selectedFile);

      const res = await fetch(`${API}/api/analyze`, { method: 'POST', body: form });

      clearInterval(stepInterval);
      steps.forEach(s => { s.classList.remove('active'); s.classList.add('done'); });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ detail: 'Unknown error' }));
        throw new Error(err.detail || `HTTP ${res.status}`);
      }

      const data = await res.json();
      renderResults(data);
      loadRecentHistory();
    } catch (err) {
      clearInterval(stepInterval);
      alert(`Analysis failed: ${err.message}`);
    } finally {
      loadingState.style.display = 'none';
      analyzeBtn.disabled = false;
    }
  });

  // ─── Render Results ───────────────────────────────────────────────────────
  function renderResults(data) {
    resultsSection.style.display = 'flex';

    // Verdict color
    const colorMap = {
      'AI Generated':    '#ff3333',
      'AI Modified':     '#ff8c00',
      'Real / Authentic':'#00e676',
    };
    const vColor = colorMap[data.verdict] || 'var(--cyan)';
    const vIcon  = data.verdict === 'AI Generated' ? '⬡' : data.verdict === 'AI Modified' ? '◈' : '◉';

    // Verdict banner
    const banner = document.getElementById('verdictBanner');
    banner.style.setProperty('--verdict-color', vColor);
    document.getElementById('verdictIcon').textContent = vIcon;
    document.getElementById('verdictIcon').style.color = vColor;
    document.getElementById('verdictText').textContent = data.verdict;
    document.getElementById('verdictText').style.color = vColor;

    // Confidence meter
    const conf = data.confidence || 0;
    const mFill = document.getElementById('meterFill');
    mFill.style.background = vColor;
    mFill.style.boxShadow = `0 0 10px ${vColor}`;
    setTimeout(() => { mFill.style.width = conf + '%'; }, 100);
    document.getElementById('confidenceVal').textContent = conf.toFixed(1) + '%';
    document.getElementById('confidenceVal').style.color = vColor;

    // Metrics
    setMetric('aiProb', 'aiProbBar', data.ai_probability || 0, '%');
    setMetric('elaScore', 'elaBar', Math.min((data.ela_score || 0) / 30 * 100, 100), '', (data.ela_score || 0).toFixed(3));
    setMetric('freqScore', 'freqBar', (data.frequency_score || 0) * 100, '', (data.frequency_score || 0).toFixed(3));
    setMetric('regionsCount', 'regionsBar', Math.min((data.regions_detected || 0) / 12 * 100, 100), '', data.regions_detected);

    document.getElementById('regionTag').textContent = `${data.regions_detected} REGIONS`;

    // Images
    document.getElementById('origImg').src = `data:image/jpeg;base64,${data.original_thumb}`;
    document.getElementById('annotatedImg').src = `data:image/png;base64,${data.annotated_image}`;
    document.getElementById('elaImg').src = `data:image/png;base64,${data.ela_image}`;
    document.getElementById('origSize').textContent = data.image_size || '--';

    // Tech readout
    const grid = document.getElementById('techGrid');
    const rows = [
      ['FILENAME',          data.filename],
      ['IMAGE SIZE',        data.image_size],
      ['VERDICT',           data.verdict],
      ['CONFIDENCE',        conf.toFixed(2) + '%'],
      ['AI PROBABILITY',    (data.ai_probability || 0).toFixed(2) + '%'],
      ['ELA MEAN SCORE',    (data.ela_score || 0).toFixed(4)],
      ['ELA MAX SCORE',     (data.ela_max || 0).toFixed(4)],
      ['FREQUENCY ANOMALY', (data.frequency_score || 0).toFixed(4)],
      ['REGIONS DETECTED',  data.regions_detected],
      ['MODEL USED',        data.model_used],
      ['RECORD ID',         data._id || 'N/A'],
    ];
    grid.innerHTML = rows.map(([k, v]) => `
      <div class="tr-row">
        <span class="tr-key">${k}</span>
        <span class="tr-val">${v}</span>
      </div>
    `).join('');

    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function setMetric(valId, barId, pct, suffix = '%', overrideVal = null) {
    const val = overrideVal !== null ? overrideVal : pct.toFixed(1);
    document.getElementById(valId).textContent = val + suffix;
    setTimeout(() => {
      document.getElementById(barId).style.width = Math.min(pct, 100) + '%';
    }, 200);
  }

  // ─── Stats ────────────────────────────────────────────────────────────────
  async function loadStats() {
    try {
      const res = await fetch(`${API}/api/stats`);
      if (!res.ok) return;
      const data = await res.json();

      document.getElementById('totalCount').textContent = data.total || 0;
      const v = data.verdicts || {};
      document.getElementById('aiCount').textContent = v['AI Generated']?.count || 0;
      document.getElementById('modCount').textContent = v['AI Modified']?.count || 0;
      document.getElementById('realCount').textContent = v['Real / Authentic']?.count || 0;
    } catch {}
  }

  // ─── Recent History ───────────────────────────────────────────────────────
  async function loadRecentHistory() {
    try {
      const res = await fetch(`${API}/api/history?limit=5`);
      if (!res.ok) return;
      const data = await res.json();
      const items = data.items || [];
      const list = document.getElementById('recentList');

      if (items.length === 0) {
        list.innerHTML = '<div class="ht-empty font-mono">No analyses yet.</div>';
        return;
      }

      const colorMap = { 'AI Generated': '#ff3333', 'AI Modified': '#ff8c00', 'Real / Authentic': '#00e676' };

      list.innerHTML = items.map(item => {
        const c = colorMap[item.verdict] || 'var(--cyan)';
        const time = new Date(item.created_at).toLocaleTimeString();
        return `
          <div class="ht-row">
            <span style="color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              ${item.filename || 'unknown'}
            </span>
            <span>
              <span class="verdict-badge" style="color:${c};background:${c}22;border:1px solid ${c}44;">
                ${item.verdict}
              </span>
            </span>
            <span style="color:var(--text-primary);">${(item.confidence || 0).toFixed(1)}%</span>
            <span style="color:var(--cyan);">${item.regions_detected ?? '--'}</span>
            <span style="color:var(--text-dim);">${time}</span>
          </div>
        `;
      }).join('');
    } catch {}
  }

  // Init
  loadStats();
  loadRecentHistory();
</script>
