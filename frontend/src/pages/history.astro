---
import Layout from '../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<Layout title="History — VISIONSCAN">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-brand">
        <div class="brand-icon">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="16" cy="16" r="8" stroke="currentColor" stroke-width="1"/>
            <circle cx="16" cy="16" r="3" fill="currentColor"/>
            <line x1="2" y1="16" x2="8" y2="16" stroke="currentColor" stroke-width="1.5"/>
            <line x1="24" y1="16" x2="30" y2="16" stroke="currentColor" stroke-width="1.5"/>
            <line x1="16" y1="2" x2="16" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <line x1="16" y1="24" x2="16" y2="30" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="brand-name font-display">VISION<span>SCAN</span></span>
      </div>
      <div class="nav-links">
        <a href="/" class="nav-link">ANALYZE</a>
        <a href="/history" class="nav-link active">HISTORY</a>
      </div>
      <div class="nav-status">
        <span class="status-dot"></span>
        <span class="font-mono" style="font-size:0.7rem;color:var(--text-secondary)">SYSTEM ONLINE</span>
      </div>
    </div>
  </nav>

  <!-- PAGE CONTENT -->
  <div class="page">
    <!-- Header -->
    <div class="page-header">
      <div>
        <div class="font-mono" style="font-size:0.7rem;color:var(--cyan);letter-spacing:0.15em;margin-bottom:0.5rem;">
          [ FORENSICS DATABASE ]
        </div>
        <h1 class="font-display" style="font-size:2.5rem;font-weight:900;letter-spacing:0.05em;">
          ANALYSIS HISTORY
        </h1>
      </div>
      <div class="filter-row">
        <div class="filter-group">
          <label class="font-mono" style="font-size:0.65rem;color:var(--text-dim);letter-spacing:0.1em;">FILTER</label>
          <select id="filterSelect" class="filter-select font-mono">
            <option value="">ALL VERDICTS</option>
            <option value="AI Generated">AI GENERATED</option>
            <option value="AI Modified">AI MODIFIED</option>
            <option value="Real / Authentic">AUTHENTIC</option>
          </select>
        </div>
        <a href="/" class="btn-primary" style="font-size:0.65rem;padding:0.6rem 1.25rem;">
          <span>+ NEW SCAN</span>
        </a>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row" id="statsRow">
      <div class="stat-card panel">
        <span class="font-mono" style="font-size:0.62rem;color:var(--text-dim);letter-spacing:0.1em;">TOTAL SCANS</span>
        <span class="font-display" id="sTotal" style="font-size:2rem;font-weight:700;">--</span>
      </div>
      <div class="stat-card panel">
        <span class="font-mono" style="font-size:0.62rem;color:var(--text-dim);letter-spacing:0.1em;">AI GENERATED</span>
        <span class="font-display text-red" id="sAI" style="font-size:2rem;font-weight:700;">--</span>
      </div>
      <div class="stat-card panel">
        <span class="font-mono" style="font-size:0.62rem;color:var(--text-dim);letter-spacing:0.1em;">AI MODIFIED</span>
        <span class="font-display text-orange" id="sMod" style="font-size:2rem;font-weight:700;">--</span>
      </div>
      <div class="stat-card panel">
        <span class="font-mono" style="font-size:0.62rem;color:var(--text-dim);letter-spacing:0.1em;">AUTHENTIC</span>
        <span class="font-display text-green" id="sReal" style="font-size:2rem;font-weight:700;">--</span>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrap panel">
      <div class="table-head font-mono">
        <span>#</span>
        <span>FILENAME</span>
        <span>VERDICT</span>
        <span>CONFIDENCE</span>
        <span>ELA SCORE</span>
        <span>REGIONS</span>
        <span>SIZE</span>
        <span>DATE / TIME</span>
        <span></span>
      </div>
      <div id="historyList">
        <div class="loading-row font-mono">
          <div class="load-dots">
            <span></span><span></span><span></span>
          </div>
          LOADING DATABASE...
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <div class="pagination" id="pagination">
      <button class="btn-ghost" id="prevBtn" disabled>← PREV</button>
      <span class="font-mono" id="pageInfo" style="font-size:0.72rem;color:var(--text-dim);">PAGE 1</span>
      <button class="btn-ghost" id="nextBtn">NEXT →</button>
    </div>
  </div>

  <!-- MODAL for viewing full result -->
  <div class="modal-overlay" id="modalOverlay" style="display:none;">
    <div class="modal panel">
      <div class="modal-header">
        <span class="font-display" style="font-size:0.8rem;letter-spacing:0.1em;color:var(--cyan);">
          FORENSIC RECORD
        </span>
        <button class="modal-close" id="modalClose">✕</button>
      </div>
      <div class="modal-body" id="modalBody">
        <!-- populated by JS -->
      </div>
    </div>
  </div>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(2, 4, 8, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-dim);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-brand { display: flex; align-items: center; gap: 0.75rem; }
  .brand-icon { width: 28px; height: 28px; color: var(--cyan); animation: spin-slow 20s linear infinite; }
  .brand-name { font-size: 1rem; letter-spacing: 0.1em; }
  .brand-name span { color: var(--cyan); }
  .nav-links { display: flex; gap: 2rem; margin-left: 2rem; }
  .nav-link {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em;
    color: var(--text-dim); text-decoration: none; transition: color 0.2s;
    padding: 0.25rem 0; border-bottom: 1px solid transparent;
  }
  .nav-link:hover, .nav-link.active { color: var(--cyan); border-bottom-color: var(--cyan); }
  .nav-status { margin-left: auto; display: flex; align-items: center; gap: 0.5rem; }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green-ok); box-shadow: 0 0 8px var(--green-ok); }

  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: fadeInUp 0.5s ease both;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .filter-row { display: flex; gap: 1rem; align-items: flex-end; }

  .filter-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .filter-select {
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    color: var(--text-primary);
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }

  .filter-select:focus { border-color: var(--cyan); }

  .btn-primary {
    background: transparent; border: 1px solid var(--cyan); color: var(--cyan);
    font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.15em;
    padding: 0.75rem 2rem; cursor: pointer; position: relative; overflow: hidden;
    transition: all 0.3s; text-transform: uppercase; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .btn-primary::before {
    content: ''; position: absolute; inset: 0; background: var(--cyan);
    transform: scaleX(0); transform-origin: left; transition: transform 0.3s; z-index: 0;
  }
  .btn-primary:hover::before { transform: scaleX(1); }
  .btn-primary:hover { color: var(--bg-void); box-shadow: var(--glow-cyan); }
  .btn-primary span { position: relative; z-index: 1; }

  .btn-ghost {
    background: transparent; border: 1px solid var(--border-dim); color: var(--text-dim);
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
    padding: 0.6rem 1.25rem; cursor: pointer; transition: all 0.2s; text-transform: uppercase;
  }
  .btn-ghost:hover:not(:disabled) { border-color: var(--text-secondary); color: var(--text-secondary); }
  .btn-ghost:disabled { opacity: 0.3; cursor: not-allowed; }

  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .stat-card { padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }

  /* TABLE */
  .table-wrap { overflow: hidden; }

  .table-head {
    display: grid;
    grid-template-columns: 40px 2fr 1.5fr 1fr 1fr 80px 100px 1.5fr 80px;
    padding: 0.6rem 1.5rem;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border-dim);
    background: var(--bg-deep);
    gap: 0.5rem;
  }

  .table-row {
    display: grid;
    grid-template-columns: 40px 2fr 1.5fr 1fr 1fr 80px 100px 1.5fr 80px;
    padding: 0.85rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border-bottom: 1px solid var(--border-dim);
    transition: background 0.2s;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .table-row:hover { background: var(--bg-hover); }
  .table-row:last-child { border-bottom: none; }

  .verdict-badge {
    font-size: 0.6rem; padding: 0.2rem 0.5rem; border-radius: 2px;
    letter-spacing: 0.04em; display: inline-block; white-space: nowrap;
  }

  .loading-row {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    padding: 3rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-dim);
  }

  .load-dots { display: flex; gap: 0.3rem; }
  .load-dots span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--cyan);
    animation: pulse-border 1.2s ease infinite;
  }
  .load-dots span:nth-child(2) { animation-delay: 0.2s; }
  .load-dots span:nth-child(3) { animation-delay: 0.4s; }

  .empty-state {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
    padding: 4rem 2rem; color: var(--text-dim); font-family: var(--font-mono); font-size: 0.75rem;
  }

  .pagination { display: flex; align-items: center; gap: 1rem; justify-content: center; }

  /* MODAL */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(2, 4, 8, 0.85); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center; padding: 2rem;
  }

  .modal {
    width: 100%; max-width: 900px; max-height: 90vh;
    overflow-y: auto; border-color: var(--border-active);
    animation: fadeInUp 0.3s ease both;
  }

  .modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 1.5rem; border-bottom: 1px solid var(--border-dim);
    position: sticky; top: 0; background: var(--bg-panel); z-index: 1;
  }

  .modal-close {
    background: none; border: none; color: var(--text-dim); font-size: 1rem; cursor: pointer;
    width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--border-dim); border-radius: 2px; transition: all 0.2s;
  }
  .modal-close:hover { border-color: var(--red-alert); color: var(--red-alert); }

  .modal-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .modal-imgs {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }

  .modal-img-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  .modal-img-label { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-dim); letter-spacing: 0.1em; }
  .modal-img-wrap img { width: 100%; max-height: 300px; object-fit: contain; border: 1px solid var(--border-dim); }

  .modal-meta {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0;
    border: 1px solid var(--border-dim);
  }

  .modal-meta-row {
    display: flex; justify-content: space-between; padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border-dim); font-family: var(--font-mono); font-size: 0.7rem;
  }
  .meta-key { color: var(--text-dim); }
  .meta-val { color: var(--text-primary); }

  @media (max-width: 768px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .table-head, .table-row {
      grid-template-columns: 2fr 1.2fr 1fr 1.5fr 60px;
    }
    .table-head span:nth-child(1),
    .table-head span:nth-child(5),
    .table-head span:nth-child(6),
    .table-head span:nth-child(7),
    .table-row > span:nth-child(1),
    .table-row > span:nth-child(5),
    .table-row > span:nth-child(6),
    .table-row > span:nth-child(7) { display: none; }
    .modal-imgs { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ API_URL }}>
  const API = API_URL;
  const LIMIT = 15;
  let currentPage = 0;
  let currentFilter = '';
  let allItems = [];

  const colorMap = {
    'AI Generated':    '#ff3333',
    'AI Modified':     '#ff8c00',
    'Real / Authentic':'#00e676',
  };

  // Load stats
  async function loadStats() {
    try {
      const res = await fetch(`${API}/api/stats`);
      if (!res.ok) return;
      const d = await res.json();
      document.getElementById('sTotal').textContent = d.total || 0;
      const v = d.verdicts || {};
      document.getElementById('sAI').textContent  = v['AI Generated']?.count || 0;
      document.getElementById('sMod').textContent = v['AI Modified']?.count || 0;
      document.getElementById('sReal').textContent = v['Real / Authentic']?.count || 0;
    } catch {}
  }

  // Load history
  async function loadHistory(page = 0, filter = '') {
    const list = document.getElementById('historyList');
    list.innerHTML = `<div class="loading-row font-mono"><div class="load-dots"><span></span><span></span><span></span></div>LOADING DATABASE...</div>`;

    try {
      const res = await fetch(`${API}/api/history?limit=100&skip=0`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      allItems = data.items || [];
    } catch (err) {
      list.innerHTML = `<div class="empty-state">⚠ Failed to load: ${err.message}</div>`;
      return;
    }

    renderPage();
  }

  function renderPage() {
    const filter = currentFilter;
    const filtered = filter ? allItems.filter(i => i.verdict === filter) : allItems;
    const start = currentPage * LIMIT;
    const pageItems = filtered.slice(start, start + LIMIT);
    const totalPages = Math.ceil(filtered.length / LIMIT);

    const list = document.getElementById('historyList');

    if (filtered.length === 0) {
      list.innerHTML = `<div class="empty-state">[ NO RECORDS MATCH FILTER ]</div>`;
    } else {
      list.innerHTML = pageItems.map((item, idx) => {
        const c = colorMap[item.verdict] || 'var(--cyan)';
        const dt = new Date(item.created_at);
        const dateStr = dt.toLocaleDateString();
        const timeStr = dt.toLocaleTimeString();
        const num = start + idx + 1;

        return `
          <div class="table-row" data-id="${item._id}" title="Click to view details">
            <span style="color:var(--text-dim)">${num}</span>
            <span style="color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                  title="${item.filename || ''}">${item.filename || 'unknown'}</span>
            <span>
              <span class="verdict-badge" style="color:${c};background:${c}22;border:1px solid ${c}44;">
                ${item.verdict || '--'}
              </span>
            </span>
            <span style="color:var(--text-primary);">${(item.confidence || 0).toFixed(1)}%</span>
            <span style="color:var(--text-secondary);">${(item.ela_score || 0).toFixed(3)}</span>
            <span style="color:var(--cyan);">${item.regions_detected ?? '--'}</span>
            <span style="color:var(--text-dim);">${item.image_size || '--'}</span>
            <span style="color:var(--text-dim);">${dateStr} ${timeStr}</span>
            <span style="color:var(--cyan);">VIEW →</span>
          </div>
        `;
      }).join('');

      // Row click handlers
      list.querySelectorAll('.table-row').forEach(row => {
        row.addEventListener('click', () => openModal(row.dataset.id));
      });
    }

    // Pagination
    document.getElementById('pageInfo').textContent = `PAGE ${currentPage + 1} / ${Math.max(1, totalPages)}`;
    document.getElementById('prevBtn').disabled = currentPage === 0;
    document.getElementById('nextBtn').disabled = currentPage >= totalPages - 1;
  }

  // Modal
  async function openModal(id) {
    const overlay = document.getElementById('modalOverlay');
    const body = document.getElementById('modalBody');
    overlay.style.display = 'flex';
    body.innerHTML = `<div class="loading-row font-mono"><div class="load-dots"><span></span><span></span><span></span></div>FETCHING RECORD...</div>`;

    try {
      const res = await fetch(`${API}/api/history/${id}`);
      if (!res.ok) throw new Error('Not found');
      const d = await res.json();
      const c = colorMap[d.verdict] || 'var(--cyan)';

      body.innerHTML = `
        <div class="modal-imgs">
          ${d.original_thumb ? `
            <div class="modal-img-wrap">
              <span class="modal-img-label">ORIGINAL IMAGE</span>
              <img src="data:image/jpeg;base64,${d.original_thumb}" alt="Original" />
            </div>
          ` : ''}
          ${d.annotated_image ? `
            <div class="modal-img-wrap">
              <span class="modal-img-label" style="color:var(--red-alert)">ANNOTATED — FLAGGED REGIONS</span>
              <img src="data:image/png;base64,${d.annotated_image}" alt="Annotated" />
            </div>
          ` : ''}
          ${d.ela_image ? `
            <div class="modal-img-wrap" style="grid-column: 1 / -1;">
              <span class="modal-img-label" style="color:var(--orange)">ELA HEATMAP</span>
              <img src="data:image/png;base64,${d.ela_image}" alt="ELA" />
            </div>
          ` : ''}
        </div>
        <div style="padding:0.75rem 1rem;background:${c}15;border:1px solid ${c}44;font-family:var(--font-mono);display:flex;align-items:center;gap:1rem;">
          <span style="font-size:1.5rem;color:${c};">${d.verdict === 'AI Generated' ? '⬡' : d.verdict === 'AI Modified' ? '◈' : '◉'}</span>
          <div>
            <div style="font-size:0.65rem;color:var(--text-dim);">VERDICT</div>
            <div style="font-size:1.1rem;font-family:var(--font-display);font-weight:700;color:${c};">${d.verdict}</div>
          </div>
          <div style="margin-left:auto;text-align:right;">
            <div style="font-size:0.65rem;color:var(--text-dim);">CONFIDENCE</div>
            <div style="font-size:1.1rem;font-family:var(--font-display);font-weight:700;color:${c};">${(d.confidence||0).toFixed(1)}%</div>
          </div>
        </div>
        <div class="modal-meta">
          ${[
            ['FILENAME', d.filename],
            ['IMAGE SIZE', d.image_size],
            ['AI PROBABILITY', (d.ai_probability||0).toFixed(2)+'%'],
            ['ELA SCORE', (d.ela_score||0).toFixed(4)],
            ['FREQ ANOMALY', (d.frequency_score||0).toFixed(4)],
            ['REGIONS DETECTED', d.regions_detected],
            ['MODEL USED', d.model_used],
            ['RECORD ID', d._id],
            ['ANALYZED AT', new Date(d.created_at).toLocaleString()],
          ].map(([k,v]) => `
            <div class="modal-meta-row">
              <span class="meta-key">${k}</span>
              <span class="meta-val">${v ?? '--'}</span>
            </div>
          `).join('')}
        </div>
      `;
    } catch (err) {
      body.innerHTML = `<div class="empty-state">⚠ Failed to load record: ${err.message}</div>`;
    }
  }

  document.getElementById('modalClose').addEventListener('click', () => {
    document.getElementById('modalOverlay').style.display = 'none';
  });
  document.getElementById('modalOverlay').addEventListener('click', e => {
    if (e.target === document.getElementById('modalOverlay')) {
      document.getElementById('modalOverlay').style.display = 'none';
    }
  });

  document.getElementById('filterSelect').addEventListener('change', e => {
    currentFilter = e.target.value;
    currentPage = 0;
    renderPage();
  });

  document.getElementById('prevBtn').addEventListener('click', () => {
    currentPage--;
    renderPage();
  });

  document.getElementById('nextBtn').addEventListener('click', () => {
    currentPage++;
    renderPage();
  });

  loadStats();
  loadHistory();
</script>
